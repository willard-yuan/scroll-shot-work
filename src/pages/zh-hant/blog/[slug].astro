---
import BlogPostPage from '../../../components/blog/BlogPostPage.astro';
import { blogLocales, getBlogPosts } from '../../../data/blog';
import '../../../styles/home.css';
import '../../../styles/blog.css';

export function getStaticPaths() {
	return getBlogPosts('zh-hant').map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const page = blogLocales['zh-hant'];
---

<BlogPostPage page={page} post={post} />
