---
import DownloadAnalytics from '../components/analytics/DownloadAnalytics.astro';
import EngagementAnalytics from '../components/analytics/EngagementAnalytics.astro';
import LanguageAnalytics from '../components/analytics/LanguageAnalytics.astro';
import BlogAnalytics from '../components/analytics/BlogAnalytics.astro';

const {
	title = 'ScrollShot - One Tap Record, Auto Long Image',
	description = 'ScrollShot turns screen recordings and screenshots into clean long images on iPhone. Auto stitch, manual stitch, fine tune seams, clean scrollbars, and share as image or PDF.',
	keywords = [],
	canonical,
	image = '/scrollshot_app_prview.webp',
	imageAlt = 'ScrollShot preview',
	lang = 'en',
	ogLocale = 'en_US',
	ogType = 'website',
	alternateLinks = [],
	jsonLd = [],
} = Astro.props;

const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon_io/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png" />
		<link rel="manifest" href="/favicon_io/site.webmanifest" />
		<meta name="description" content={description} />
		{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
		{canonical && <link rel="canonical" href={canonical} />}
		{
			alternateLinks.map((link: { lang: string; href: string }) => (
				<link rel="alternate" hreflang={link.lang} href={link.href} />
			))
		}
		<meta name="theme-color" content="#EB5332" />
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content="ScrollShot" />
		<meta property="og:locale" content={ogLocale} />
		{
			alternateLinks
				.filter((link: { lang: string }) => link.lang !== 'x-default' && link.lang !== lang)
				.map((link: { lang: string }) => (
					<meta property="og:locale:alternate" content={link.lang.replace('-', '_')} />
				))
		}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonical && <meta property="og:url" content={canonical} />}
		<meta property="og:image" content={image} />
		<meta property="og:image:alt" content={imageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		<meta name="twitter:image:alt" content={imageAlt} />
		<meta name="generator" content={Astro.generator} />
		<script defer src="https://cloud.umami.is/script.js" data-website-id="f9899ab0-197b-4793-9168-de78a39c8897"></script>
		<title>{title}</title>
		{jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
	</head>
	<body>
		<slot />
		<DownloadAnalytics />
		<EngagementAnalytics />
		<LanguageAnalytics />
		<BlogAnalytics />
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		scroll-behavior: smooth;
		background: #080909;
		color: #f6f4ee;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text",
			"Segoe UI", "Noto Sans", "Helvetica Neue", Arial, sans-serif;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}

	:global(body) {
		overflow-x: hidden;
	}

	:global(img),
	:global(video) {
		max-width: 100%;
		display: block;
	}

	:global(a) {
		color: inherit;
	}
</style>
