---
interface LinkItem {
	label: string;
	href: string;
}

interface Props {
	content: {
		kicker: string;
		title: string;
		text: string;
		primary: LinkItem;
		secondary: LinkItem;
	};
}

const { content } = Astro.props;
---

<aside class="blog-conversion" aria-labelledby="blog-conversion-title">
	<p class="eyebrow gold">{content.kicker}</p>
	<h2 id="blog-conversion-title">{content.title}</h2>
	<p>{content.text}</p>
	<div class="blog-conversion-actions">
		<a class="button button-mint" href={content.primary.href} target="_blank" rel="noopener noreferrer">
			{content.primary.label}
		</a>
		<a class="button button-ghost" href={content.secondary.href} target="_blank" rel="noopener noreferrer">
			{content.secondary.label}
		</a>
	</div>
</aside>
