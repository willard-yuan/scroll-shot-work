---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../home/SiteNav.astro';
import SiteFooter from '../home/SiteFooter.astro';
import BlogConversionBlock from './BlogConversionBlock.astro';
import type { BlogLocale, BlogPost } from '../../data/blog';
import {
	buildBlogPostJsonLd,
	getBlogHomeHref,
	getBlogLanguageLinks,
	getBlogNavLinks,
	getBlogPostAlternates,
} from '../../data/blog';
import { site } from '../../data/home';

interface Props {
	page: BlogLocale;
	post: BlogPost;
}

const { page, post } = Astro.props;
const home = page.home;
const Content = post.Content;
const navLinks = getBlogNavLinks(page.locale, 'post');
const homeHref = getBlogHomeHref(page.locale, 'post');
const blogHref = '../';
const dateLocale =
	page.locale === 'zh'
		? 'zh-CN'
		: page.locale === 'zh-hant'
			? 'zh-TW'
			: page.locale === 'ja'
				? 'ja-JP'
				: page.locale === 'ko'
					? 'ko-KR'
					: page.locale === 'de'
						? 'de-DE'
						: page.locale === 'fr'
							? 'fr-FR'
							: page.locale === 'es'
								? 'es-ES'
								: page.locale === 'pt-br'
									? 'pt-BR'
									: page.locale === 'it'
										? 'it-IT'
										: page.locale === 'vi'
											? 'vi-VN'
											: 'en-US';
const formatDate = (date: string) =>
	new Intl.DateTimeFormat(dateLocale, {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(new Date(`${date}T00:00:00`));
const blogConversion = 'blogConversion' in home ? home.blogConversion : undefined;
---

<Layout
	title={`${post.title} | ScrollShot Blog`}
	description={post.description}
	keywords={post.tags}
	canonical={post.url}
	image={`${site.url}${post.cover.slice(1)}`}
	imageAlt={post.coverAlt}
	lang={page.lang}
	ogLocale={page.ogLocale}
	ogType="article"
	alternateLinks={getBlogPostAlternates(post)}
	jsonLd={buildBlogPostJsonLd(post, page)}
>
	<div class="site-shell blog-shell">
		<SiteNav
			icon={home.assets.appIcon}
			links={navLinks}
			appStoreUrl={page.appStoreUrl}
			brandHref={homeHref}
			labels={home.navLabels}
		/>

		<main class="blog-main">
			<article class="blog-post">
				<header class="blog-post-header">
					<nav class="blog-breadcrumbs" aria-label="Breadcrumb">
						<a href={homeHref}>{page.copy.home}</a>
						<span class="sep" aria-hidden="true">&rsaquo;</span>
						<a href={blogHref}>{page.copy.kicker}</a>
						<span class="sep" aria-hidden="true">&rsaquo;</span>
						<span class="current">{post.title}</span>
					</nav>
					
					<h1>{post.title}</h1>
					
					<div class="blog-post-meta">
						<div class="meta-item">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
							<time datetime={post.date}>{formatDate(post.date)}</time>
						</div>
						<span class="dot" aria-hidden="true">·</span>
						<div class="meta-item">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
							<span>{post.readingTime}</span>
						</div>
						<span class="dot" aria-hidden="true">·</span>
						<div class="meta-item author">
							<span>{post.author || page.copy.articleByline}</span>
						</div>
					</div>
				</header>

				<figure class="blog-post-cover">
					<img src={post.cover} alt={post.coverAlt} loading="eager" />
				</figure>

				<div class="blog-prose">
					<Content />
				</div>

				{blogConversion && <BlogConversionBlock content={blogConversion} />}

				<footer class="blog-post-footer">
					<div class="blog-tags" aria-label="Article tags">
						{post.tags.map((tag) => <span>{tag}</span>)}
					</div>
					<a class="blog-read-link" href={blogHref}>{page.copy.backToBlog}</a>
				</footer>
			</article>
		</main>

		<SiteFooter
			icon={home.assets.appIcon}
			appStoreUrl={page.appStoreUrl}
			video={home.assets.video}
			homeHref={homeHref}
			brandHref={homeHref}
			legalLinks={home.legalLinks}
			content={{
				...home.footer,
				languageLinks: getBlogLanguageLinks(page.locale),
			}}
		/>
	</div>
</Layout>
