---
import BrandMark from './BrandMark.astro';

interface LinkItem {
	label: string;
	href: string;
}

interface Props {
	icon: string;
	appStoreUrl: string;
	video: string;
	homeHref?: string;
	brandHref?: string;
	legalLinks: LinkItem[];
	content: {
		brandHome: string;
		note: string;
		productTitle: string;
		featuresLabel: string;
		reviewsLabel: string;
		pricingLabel: string;
		downloadTitle: string;
		appStoreLabel: string;
		videoLabel: string;
		legalTitle: string;
		supportedLanguagesTitle?: string;
		supportedLanguagesText?: string;
		languageSwitcherTitle?: string;
		languageSwitcherAria?: string;
		languageLabel?: string;
		languageHref?: string;
		languageLinks?: LinkItem[];
	};
}

const { icon, appStoreUrl, video, homeHref = '', brandHref, legalLinks, content } = Astro.props;
const languageLinks =
	content.languageLinks?.length
		? content.languageLinks
		: content.languageHref && content.languageLabel
			? [{ label: content.languageLabel, href: content.languageHref }]
			: [];
---

<footer class="footer">
	<div class="footer-top">
		<div>
			<BrandMark icon={icon} href={brandHref} ariaLabel={content.brandHome} />
			<p class="footer-note">{content.note}</p>
		</div>
		<div class="footer-columns">
			<div>
				<h3>{content.productTitle}</h3>
				<a href={`${homeHref}#features`}>{content.featuresLabel}</a>
				<a href={`${homeHref}#reviews`}>{content.reviewsLabel}</a>
				<a href={`${homeHref}#pricing`}>{content.pricingLabel}</a>
			</div>
			<div>
				<h3>{content.downloadTitle}</h3>
				<a href={appStoreUrl} target="_blank" rel="noopener noreferrer">{content.appStoreLabel}</a>
				<a href={video} target="_blank" rel="noopener noreferrer">{content.videoLabel}</a>
			</div>
			<div>
				<h3>{content.legalTitle}</h3>
				{legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
			</div>
		</div>
	</div>

	<div class="footer-language-support">
		<h3>{content.supportedLanguagesTitle ?? 'Supported Languages'}</h3>
		<p>
			{
				content.supportedLanguagesText ??
					'English, 简体中文, 繁體中文, 日本語, 한국어, Deutsch, Français, Español, Italiano, Português, Nederlands, Русский, Türkçe, Polski, Bahasa Indonesia, Tiếng Việt, ไทย, हिन्दी, العربية and more.'
			}
		</p>
	</div>

	{
		languageLinks.length > 0 && (
			<div class="footer-bottom">
				<span>{content.languageSwitcherTitle ?? 'Website Languages'}</span>
				<nav class="footer-language-nav" aria-label={content.languageSwitcherAria ?? 'Change website language'}>
					{languageLinks.map((link) => (
						<a href={link.href}>{link.label}</a>
					))}
				</nav>
			</div>
		)
	}
</footer>
