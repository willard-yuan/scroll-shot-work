---
import BrandMark from './BrandMark.astro';

interface LinkItem {
	label: string;
	href: string;
}

interface Props {
	icon: string;
	appStoreUrl: string;
	video: string;
	homeHref?: string;
	brandHref?: string;
	legalLinks: LinkItem[];
	content: {
		brandHome: string;
		note: string;
		productTitle: string;
		featuresLabel: string;
		reviewsLabel: string;
		pricingLabel: string;
		downloadTitle: string;
		appStoreLabel: string;
		videoLabel: string;
		legalTitle: string;
		languageLabel?: string;
		languageHref?: string;
		languageLinks?: LinkItem[];
	};
}

const { icon, appStoreUrl, video, homeHref = '', brandHref, legalLinks, content } = Astro.props;
---

<footer class="footer">
	<div class="footer-top">
		<div>
			<BrandMark icon={icon} href={brandHref} ariaLabel={content.brandHome} />
			<p class="footer-note">{content.note}</p>
		</div>
		<div class="footer-columns">
			<div>
				<h3>{content.productTitle}</h3>
				<a href={`${homeHref}#features`}>{content.featuresLabel}</a>
				<a href={`${homeHref}#reviews`}>{content.reviewsLabel}</a>
				<a href={`${homeHref}#pricing`}>{content.pricingLabel}</a>
				{content.languageLinks?.map((link) => <a href={link.href}>{link.label}</a>)}
				{!content.languageLinks?.length && content.languageHref && content.languageLabel && (
					<a href={content.languageHref}>{content.languageLabel}</a>
				)}
			</div>
			<div>
				<h3>{content.downloadTitle}</h3>
				<a href={appStoreUrl}>{content.appStoreLabel}</a>
				<a href={video}>{content.videoLabel}</a>
			</div>
			<div>
				<h3>{content.legalTitle}</h3>
				{legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
			</div>
		</div>
	</div>
</footer>
