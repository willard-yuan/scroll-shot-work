---
interface Props {
	appStoreUrl: string;
	video: string;
	videoCover: string;
	content: {
		eyebrow: string;
		title: string;
		subtitle: string;
		text: string;
		primaryCta: string;
		secondaryCta: string;
		videoAria: string;
		videoLabel: string;
		caption: string;
		trustSignals?: Array<{
			value?: string;
			label: string;
			note?: string;
			tone?: 'rating' | 'privacy' | 'export';
		}>;
	};
}

const { appStoreUrl, video, videoCover, content } = Astro.props;
---

<section class="hero" id="top">
	<div class="hero-copy">
		<p class="eyebrow">{content.eyebrow}</p>
		<h1>{content.title}</h1>
		<h2>{content.subtitle}</h2>
		<p class="hero-text">{content.text}</p>
		<div class="hero-actions">
			<a class="button button-light button-lg" href={appStoreUrl} target="_blank" rel="noopener noreferrer">
				<span class="apple-mark" aria-hidden="true"></span>
				{content.primaryCta}
			</a>
			<a class="button button-ghost button-lg" href={video} target="_blank" rel="noopener noreferrer">
				{content.secondaryCta}
			</a>
		</div>
		{
			content.trustSignals && (
				<div class="hero-trust-list" aria-label="ScrollShot 信任信号">
					{content.trustSignals.map((item) => (
						<div class:list={['hero-trust-item', item.tone && `trust-${item.tone}`]}>
							{item.value && <strong>{item.value}</strong>}
							<span>{item.label}</span>
							{item.note && <small>{item.note}</small>}
						</div>
					))}
				</div>
			)
		}
	</div>

	<a class="hero-device-link" href={video} aria-label={content.videoAria} target="_blank" rel="noopener noreferrer">
		<div class="device-shell">
			<div class="device-screen video-screen">
				<video
					src={video}
					poster={videoCover}
					width="886"
					height="1920"
					autoplay
					muted
					loop
					playsinline
					preload="metadata"
					aria-label={content.videoLabel}
				></video>
			</div>
		</div>
		<span class="device-caption">{content.caption}</span>
	</a>
</section>
