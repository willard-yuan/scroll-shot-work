---
import BrandMark from './BrandMark.astro';
import LanguageSwitcher from '../LanguageSwitcher.astro';
import type { SwitcherItem } from '../../data/languages';

interface Props {
	icon: string;
	links: Array<{ href: string; label: string; current?: boolean }>;
	appStoreUrl: string;
	brandHref?: string;
	labels: {
		navAria: string;
		linksAria: string;
		install: string;
		brandHome: string;
		menu: string;
	};
	languageSwitcher?: SwitcherItem[];
	switcherLabels?: { triggerAria: string; menuAria: string };
}

const { icon, links, appStoreUrl, brandHref, labels, languageSwitcher, switcherLabels } = Astro.props;
const defaultSwitcherLabels = { triggerAria: 'Change language', menuAria: 'Choose language' };
---

<header class="nav-wrap">
	<nav class="nav" aria-label={labels.navAria}>
		<BrandMark icon={icon} href={brandHref} ariaLabel={labels.brandHome} />
		<div class="nav-links" aria-label={labels.linksAria}>
			{links.map((link) => <a href={link.href} aria-current={link.current ? 'page' : undefined}>{link.label}</a>)}
		</div>
		<div class="nav-actions">
			{
				languageSwitcher && languageSwitcher.length > 1 && (
					<LanguageSwitcher
						class="lang-switcher--nav"
						items={languageSwitcher}
						labels={switcherLabels ?? defaultSwitcherLabels}
					/>
				)
			}
			<a class="nav-button" href={appStoreUrl} target="_blank" rel="noopener noreferrer">{labels.install}</a>
			<button
				class="mobile-menu-toggle"
				type="button"
				aria-label={labels.menu}
				aria-expanded="false"
				aria-controls="mobile-nav-menu"
			>
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
			</button>
		</div>
	</nav>
	<div class="mobile-menu" id="mobile-nav-menu" hidden>
		<div class="mobile-menu-panel" aria-label={labels.linksAria}>
			{links.map((link) => <a href={link.href} aria-current={link.current ? 'page' : undefined}>{link.label}</a>)}
			{
				languageSwitcher && languageSwitcher.length > 1 && (
					<LanguageSwitcher
						class="lang-switcher--mobile"
						items={languageSwitcher}
						labels={switcherLabels ?? defaultSwitcherLabels}
					/>
				)
			}
		</div>
	</div>
</header>

<script is:inline>
	document.querySelectorAll('.nav-wrap').forEach((navWrap) => {
		const toggle = navWrap.querySelector('.mobile-menu-toggle');
		const menu = navWrap.querySelector('.mobile-menu');

		if (!toggle || !menu) {
			return;
		}

		let closeTimer;

		const setMenu = (open) => {
			window.clearTimeout(closeTimer);
			toggle.setAttribute('aria-expanded', String(open));

			if (open) {
				menu.hidden = false;
				window.requestAnimationFrame(() => navWrap.classList.add('menu-open'));
				return;
			}

			navWrap.classList.remove('menu-open');
			closeTimer = window.setTimeout(() => {
				menu.hidden = true;
			}, 180);
		};

		toggle.addEventListener('click', () => {
			setMenu(toggle.getAttribute('aria-expanded') !== 'true');
		});

		menu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => setMenu(false));
		});

		document.addEventListener('click', (event) => {
			if (!navWrap.contains(event.target) && toggle.getAttribute('aria-expanded') === 'true') {
				setMenu(false);
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
				setMenu(false);
				toggle.focus();
			}
		});
	});
</script>
